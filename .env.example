# ─────────────────────────────────────────────────────────────────────────────
# volumen-vault — Configuración
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo a `.env` y completa los valores.
# NUNCA commitees `.env` al repo (ya está en .gitignore).

# Autenticación pCloud.
# Opción A (default): email + password
PCLOUD_EMAIL=tu_cuenta@gmail.com
PCLOUD_PASSWORD=tu_password
# Opción B (recomendada para servers): si el método digest falla
# desde el server (1022 'Please provide code'), pre-cachea un token
# generado localmente y ponlo aquí. Los tokens NO expiran salvo que
# cambies la password.
# PCLOUD_AUTH_TOKEN=iyKG6ZzSQC7ZpYLxK6IuJK07qWJreNFVg88VLLcX
PCLOUD_REGION=us
# Folder raíz donde se guardan los snapshots. Crea uno dedicado en pCloud y
# pega su ID aquí. Para crear uno: abre pCloud web → New Folder → "volumen-vault"
# luego click derecho → "Get link" → el número después de folder/ es el ID.
PCLOUD_VAULT_FOLDER_ID=0

# Cuándo correr el snapshot automático (formato cron estándar: "min hour dom mon dow")
# "0 2 * * *" = todos los días a las 02:00
# "*/30 * * * *" = cada 30 minutos (testing)
# "" = deshabilitar scheduler (solo corre manual via API)
SNAPSHOT_CRON=0 2 * * *

# Retención: cuántos snapshots por volumen mantener en pCloud antes de purgar
# los más viejos. 0 = nunca borrar (papelera infinita, ⚠ llena tu quota)
RETENTION_SNAPSHOTS=30

# Qué volúmenes incluir/excluir (regex, separadas por coma, sin espacios)
# Default: snapshot todo. Excluir típicos: temp, cache, logs
INCLUDE_PATTERN=.*
EXCLUDE_PATTERN=^($|.tmp$|.cache$)

# API REST (puerto host)
API_PORT=8095
API_KEY=  # dejar vacío para deshabilitar auth (solo si no expones el puerto)

# Modo debug (más logs)
DEBUG=false
